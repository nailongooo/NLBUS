# 复制这个文件为 .env 并按你自己的服务器信息修改
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=bus_tracker
DB_PASSWORD=请修改为你自己的数据库密码
DB_NAME=bus_tracker

# 用于签发普通用户 / 管理员 JWT 的密钥，请改成一段随机字符串（越长越随机越好）
JWT_SECRET=请改成一段足够长且随机的字符串

# 允许跨域访问的来源，多个用逗号分隔；App 本身不受 CORS 限制，这个主要是给 admin-web 用的
CORS_ORIGIN=https://your-domain.com
